# Gemini API（Vincent 已付費帳號）
GEMINI_API_KEY=your_gemini_api_key_here

# Notion
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_database_id_here

# GitHub（用於推 .ics 到 GitHub Pages）
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=your_username/exhibition-tracker

# Finnhub API（用於抓美股龍頭 quarterly earnings）
# 免費註冊：https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# Perplexity API（Layer 2 即時 web 搜尋 → Claude 整理/複核）
# 設定後 update_all 預設改用 Perplexity 當查詢/發現引擎；未設定則回退 Claude CLI
# 取得：https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
# 選填，預設 sonar-pro
PERPLEXITY_MODEL=sonar-pro

# 總經數據行事曆（公開 ICS，預設為財經 M 平方全球財經日曆，可換成自己的）
# 留空則用程式內建預設值
MACRO_ICS_URL=
